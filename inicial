import cv2
from ultralytics import YOLO
import os
import time

# 1. Configurações Iniciais
# Substitua pela sua URL que testamos antes
url_camera = "rtsp://admin:testecasa01@10.0.10.228:554/onvif1"
modelo = YOLO('yolov8n-pose.pt') # Modelo leve e rápido

# Cria as pastas para a IA aprender depois
os.makedirs("capturas/quedas", exist_ok=True)
os.makedirs("capturas/normal", exist_ok=True)

cap = cv2.VideoCapture(url_camera)

print("Iniciando monitoramento... Pressione 'q' para sair.")

while cap.isOpened():
    success, frame = cap.read()
    if not success:
        print("Falha ao receber stream da lâmpada.")
        break

    # 2. Executa a IA no frame
    results = modelo(frame, verbose=False)

    for r in results:
        # Pega as caixas de detecção (Bounding Boxes)
        boxes = r.boxes
        for box in boxes:
            # Coordenadas da caixa: x1, y1, x2, y2
            x1, y1, x2, y2 = box.xyxy[0].cpu().numpy()
            largura = x2 - x1
            altura = y2 - y1
            
            # 3. Lógica de Veredito Inicial
            # Se a largura for maior que a altura, há chance de queda
            is_deitado = largura > altura
            
            # Desenha na tela para você visualizar
            cor = (0, 0, 255) if is_deitado else (0, 255, 0)
            cv2.rectangle(frame, (int(x1), int(y1)), (int(x2), int(y2)), cor, 2)
            
            label = "QUEDA DETECTADA" if is_deitado else "NORMAL"
            cv2.putText(frame, label, (int(x1), int(y1)-10), cv2.FONT_HERSHEY_SIMPLEX, 0.5, cor, 2)

            # 4. Salva amostras para a IA aprender (ex: a cada 5 segundos para não lotar o HD)
            if is_deitado:
                timestamp = int(time.time())
                cv2.imwrite(f"capturas/quedas/queda_{timestamp}.jpg", frame)
                # Aqui no futuro iria o comando para enviar o alerta ao App Kotlin

    # Mostra o vídeo em tempo real no PC
    cv2.imshow("Monitoramento IA - Quintal", frame)

    if cv2.waitKey(1) & 0xFF == ord('q'):
        break

cap.release()
cv2.destroyAllWindows()